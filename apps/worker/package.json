{
  "name": "@flop/worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply flop-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply flop-db --remote",
    "types": "wrangler types",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "@flop/shared": "workspace:*",
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.39.1",
    "hono": "^4.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "wrangler": "^4.4.0"
  }
}
